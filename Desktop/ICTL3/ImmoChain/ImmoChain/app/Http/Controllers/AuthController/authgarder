    public function register(Request $request)
    {
        Log::info('Dûˋbut de la mûˋthode register');
        Log::info('Donnûˋes reûÏues:', $request->all());

        try {
            $validatedData = $request->validate([
                'name' => 'required|string|max:255',
                'birthdate' => 'required|date|before:-18 years',
                'phone' => 'required|string|unique:users,telephone|regex:/^[6-9][0-9]{8}$/',
                'address' => 'required|string',
                'cni_front' => 'required|string',
                'cni_back' => 'required|string',
                'facial_scan' => 'required|string',
                'password' => 'required|string|min:8|confirmed',
                'terms' => 'required|accepted',
            ]);

            Log::info('Validation des donnûˋes rûˋussie');

            $user = new User();
            $user->name = $validatedData['name'];
            $user->telephone = $validatedData['phone'];
            $user->password = Hash::make($validatedData['password']);
            $user->adresse = $validatedData['address'];
            $user->type_utilisateur = 'expûˋditeur';
            $user->date_naissance = $validatedData['birthdate'];

            // Store CNI and facial scan images
            $user->cni_front = $this->storeImage($validatedData['cni_front'], 'cni_front');
            $user->cni_back = $this->storeImage($validatedData['cni_back'], 'cni_back');
            $user->facial_scan = $this->storeImage($validatedData['facial_scan'], 'facial_scan');

            $user->save();

            Log::info('Utilisateur enregistrûˋ avec succû´s');

            // Generate and send WhatsApp verification code
            $verificationCode = $this->generateVerificationCode();
            $this->sendWhatsAppVerificationCode($validatedData['phone'], $verificationCode);

            // Store verification code and phone number in the session
            session(['whatsapp_verification_code' => $verificationCode]);
            session(['registered_phone' => $validatedData['phone']]);

            return response()->json([
                'success' => true,
                'message' => 'Inscription rûˋussie. Veuillez vûˋrifier votre numûˋro WhatsApp.',
            ]);
        } catch (\Exception $e) {
            Log::error('Erreur lors de l\'inscription : ' . $e->getMessage());
            return response()->json([
                'success' => false,
                'message' => 'Une erreur est survenue lors de l\'inscription. Veuillez rûˋessayer.',
                'error' => $e->getMessage()
            ], 500);
        }
    }

    private function sendWhatsAppVerificationCode($phoneNumber, $verificationCode)
    {
        $sid = env('TWILIO_SID');
        $token = env('TWILIO_TOKEN');
        $twilioWhatsAppNumber = env('TWILIO_WHATSAPP_NUMBER');
        
        $client = new Client($sid, $token);
        
        $client->messages->create(
            'whatsapp:+' . $phoneNumber, // Destinataire
            [
                'from' => 'whatsapp:' . $twilioWhatsAppNumber,
                'body' => "Votre code de vûˋrification est : {$verificationCode}"
            ]
        );
    }

    public function verifyWhatsApp(Request $request)
{
    $request->validate([
        'code' => 'required|string',
    ]);

    $storedCode = session('whatsapp_verification_code');

    if ($request->code === $storedCode) {
        $user = User::where('telephone', session('registered_phone'))->first();
        $user->telephone_verified_at = now();
        $user->save();

        // Clear session after verification
        session()->forget(['whatsapp_verification_code', 'registered_phone']);

        return response()->json([
            'success' => true,
            'message' => 'Numûˋro WhatsApp vûˋrifiûˋ avec succû´s.',
        ]);
    }

    return response()->json([
        'success' => false,
        'message' => 'Code de vûˋrification incorrect.',
    ], 400);
}


    private function storeImage($base64Image, $prefix)
    {
        try {
            $image = str_replace('data:image/jpeg;base64,', '', $base64Image);
            $image = str_replace(' ', '+', $image);
            $imageName = $prefix . '_' . Str::random(10) . '.jpg';
            
            Storage::disk('public')->put('user_documents/' . $imageName, base64_decode($image));
            
            return 'user_documents/' . $imageName;
        } catch (\Exception $e) {
            Log::error('Erreur lors du stockage de l\'image : ' . $e->getMessage());
            throw $e;
        }
    }

    private function generateVerificationCode()
    {
        return str_pad(rand(0, 999999), 6, '0', STR_PAD_LEFT);
    }

