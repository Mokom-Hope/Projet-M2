    public function loginp(Request $request)
{
    // Validation des donnûˋes d'entrûˋe
    $validator = Validator::make($request->all(), [
        'telephone' => [
            'required',
            'regex:/^6[2356789][0-9]{7}$/',
            'string',
            'size:9',
        ],
        'password' => [
            'required',
            'string',
            'min:8',
            'regex:/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};:"\\|,.<>\/?]).+$/',
        ],
    ], [
        'telephone.required' => 'Le numûˋro de tûˋlûˋphone est requis.',
        'telephone.regex' => 'Le format du numûˋro de tûˋlûˋphone est incorrect.',
        'telephone.size' => 'Le numûˋro de tûˋlûˋphone doit contenir exactement 9 chiffres.',
        'password.required' => 'Le mot de passe est requis.',
        'password.min' => 'Le mot de passe doit contenir au moins 8 caractû´res.',
        'password.regex' => 'Le mot de passe doit contenir au moins une majuscule, une minuscule, un chiffre et un caractû´re spûˋcial.',
    ]);

    if ($validator->fails()) {
        return back()->withErrors($validator)->withInput();
    }

    $credentials = $request->only('telephone', 'password');

    // Tentative de connexion
    if (Auth::attempt($credentials, $request->has('remember-me'))) {
        $request->session()->regenerate(); // Empûˆche le dûˋtournement de session

        // Redirection sûˋcurisûˋe vers le tableau de bord
        return redirect()->intended('Dashboard')->with('success', 'Connexion rûˋussie.');
    }

    // Si la connexion ûˋchoue
    return back()->withErrors([
        'telephone' => 'Numûˋro de tûˋlûˋphone ou mot de passe incorrect.',
    ])->withInput();
}

    public function logout(Request $request)
    {
        Auth::logout();

        $request->session()->invalidate();

        $request->session()->regenerateToken();

        return redirect('/login');
    }

}
