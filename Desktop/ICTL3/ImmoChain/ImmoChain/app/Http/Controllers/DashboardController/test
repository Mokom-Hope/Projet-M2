<script>
    mapboxgl.accessToken = 'pk.eyJ1IjoiYXJ0aHVyLWNhZHJlbjIzNyIsImEiOiJjbTM1cjE0cGUwNW41Mmlvam56ZjRtdXQzIn0.fWB_Y31S2A3WeZvXoxjDxQ';
    let map;
    let userMarker;
    let watchId;

    // Fonction pour initialiser la carte avec la position de l'utilisateur
    function initializeMap(longitude, latitude) {
        map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/streets-v11',
            center: [longitude, latitude],
            zoom: 13
        });

        // Ajouter un marqueur pour la position de l'utilisateur
        userMarker = new mapboxgl.Marker({ color: '#3498db' })
            .setLngLat([longitude, latitude])
            .addTo(map);


        // Commencer à suivre la position de l'utilisateur
        startTracking();

        // Charger les colis à proximité
        loadNearbyPackages(longitude, latitude);
    }

    // Fonction pour commencer à suivre la position de l'utilisateur
    function startTracking() {
        if ("geolocation" in navigator) {
            watchId = navigator.geolocation.watchPosition(updateUserPosition, handleLocationError, {
                enableHighAccuracy: true,
                timeout: 5000,
                maximumAge: 0
            });
        }
    }

    // Fonction pour mettre à jour la position de l'utilisateur
    function updateUserPosition(position) {
        const { longitude, latitude } = position.coords;
        userMarker.setLngLat([longitude, latitude]);
        map.setCenter([longitude, latitude]);

        // Recharger les colis à proximité
        loadNearbyPackages(longitude, latitude);
    }

    // Fonction pour gérer les erreurs de géolocalisation
    function handleLocationError(error) {
        console.error("Erreur de géolocalisation : ", error);
        alert("Impossible d'obtenir votre position. Veuillez vérifier vos paramètres de localisation.");
    }

    // Fonction pour charger les colis à proximité
    async function loadNearbyPackages(longitude, latitude) {
    try {
        const response = await fetch(`/colis-proximite?latitude=${latitude}&longitude=${longitude}`);
        const result = await response.json();

        if (result.success) {
            // Supprimer les anciens marqueurs de colis
            document.querySelectorAll('.package-marker').forEach(el => el.remove());

            // Ajouter les nouveaux marqueurs de colis
            result.data.forEach(addPackageMarker);

            // Mettre à jour la liste des missions disponibles
            updateAvailableMissions(result.data);
        }
    } catch (error) {
        console.error('Erreur lors du chargement des colis:', error);
    }
}

    // Fonction pour ajouter un marqueur de colis sur la carte
    function addPackageMarker(colis) {
    const el = document.createElement('div');
    el.className = 'package-marker';
    el.style.backgroundImage = 'url(https://img.icons8.com/color/48/000000/box.png)';
    el.style.width = '30px';
    el.style.height = '30px';
    el.style.backgroundSize = '100%';

    el.addEventListener('click', () => showMissionDetails(colis));

    new mapboxgl.Marker(el)
        .setLngLat([colis.longitude, colis.latitude])
        .addTo(map);
}

    // Fonction pour mettre à jour la liste des missions disponibles
    function updateAvailableMissions(colis) {
    const missionsContainer = document.getElementById('availableMissions');
    missionsContainer.innerHTML = '';

    colis.forEach(colis => {
        const missionElement = document.createElement('div');
        missionElement.className = 'border-b pb-4';
        missionElement.innerHTML = `
            <h3 class="font-medium">${colis.description}</h3>
            <p class="text-sm text-gray-600">Destination: ${colis.destination} - Poids: ${colis.poids} kg</p>
            <button onclick='showMissionDetails(${JSON.stringify(colis)})' class="mt-2 bg-coligo-blue text-white py-1 px-3 rounded-lg text-sm hover:bg-coligo-orange transition duration-300">
                Voir détails
            </button>
        `;
        missionsContainer.appendChild(missionElement);
    });
}

    // Fonction pour afficher les détails d'une mission
    function showMissionDetails(colis) {
    const modal = document.getElementById('missionDetailsModal');
    const detailsContainer = document.getElementById('missionDetails');
    detailsContainer.innerHTML = `
        <img src="/${colis.imgColis}" alt="Image du colis" class="w-full h-48 object-cover rounded-lg mb-4">
        <h4 class="font-bold">${colis.description}</h4>
        <p>Destination: ${colis.destination}</p>
        <p>Poids: ${colis.poids} kg</p>
        <p>Prix: ${colis.valeur} FCFA</p>
        <p>Heure de départ: ${new Date(colis.heure_depart).toLocaleString()}</p>
    `;
    
    modal.classList.remove('hidden');

    document.getElementById('acceptMissionBtn').onclick = () => acceptMission(colis.id);
    document.getElementById('closeMissionDetailsBtn').onclick = () => modal.classList.add('hidden');
}

    // Fonction pour accepter une mission
    function acceptMission(missionId) {
        // Simuler l'acceptation d'une mission (à remplacer par une vraie requête API)
        alert(`Mission ${missionId} acceptée !`);
        document.getElementById('missionDetailsModal').classList.add('hidden');
        // Recharger les missions disponibles après acceptation
        const { lng, lat } = userMarker.getLngLat();
        loadNearbyPackages(lng, lat);
    }

    // Gestionnaire pour le bouton d'envoi de colis
    document.getElementById('sendPackageBtn').addEventListener('click', () => {
        document.getElementById('sendPackageModal').classList.remove('hidden');
    });

    // Gestionnaire pour le formulaire d'envoi de colis
    document.getElementById('sendPackageForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Récupération des valeurs
    const description = document.getElementById('packageDescription').value;
    const destination = document.getElementById('packageDestination').value;
    const weight = document.getElementById('packageWeight').value;
    const departureTime = document.getElementById('packageDepartureTime').value;
    const value = document.getElementById('deliveryPrice').value;
    const packageImageInput = document.getElementById('packageImage');
    const imageFile = packageImageInput ? packageImageInput.value : null

    // Vérification du prix minimum
    if (value < 500) {
        alert("Le prix de livraison doit être supérieur ou égal à 500 FCFA.");
        return;
    }

    try {
        // Récupération de la position actuelle
        const position = userMarker.getLngLat();
        
        // Création de l'objet FormData
        const formData = new FormData();
        formData.append('description', description);
        formData.append('poids', weight);
        formData.append('valeur', value);
        formData.append('latitude', position.lat);
        formData.append('longitude', position.lng);
        formData.append('destination', destination);
        formData.append('heure_depart', departureTime);
        formData.append('image', imageFile);

        // Envoi de la requête
        const response = await fetch('/enregistrerColis', {
            method: 'POST',
            headers: {
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                'Accept': 'application/json'
            },
            body: formData
        });

        const result = await response.json();

        if (result.success) {
            alert('Colis enregistré avec succès !');
            document.getElementById('sendPackageModal').classList.add('hidden');
            // Recharger les colis à proximité
            const { lng, lat } = userMarker.getLngLat();
            loadNearbyPackages(lng, lat);
        } else {
            alert(result.message || 'Une erreur est survenue lors de l\'enregistrement du colis.');
        }
    } catch (error) {
        console.error('Erreur:', error);
        alert('Une erreur est survenue lors de l\'enregistrement du colis.');
    }
});


    // Gestionnaire pour la recherche de missions
    document.getElementById('searchMissions').addEventListener('input', (e) => {
        const searchTerm = e.target.value.toLowerCase();
        const missions = document.getElementById('availableMissions').children;
        Array.from(missions).forEach(mission => {
            const description = mission.querySelector('h3').textContent.toLowerCase();
            if (description.includes(searchTerm)) {
                mission.style.display = '';
            } else {
                mission.style.display = 'none';
            }
        });
    });

    // Fonction pour charger les activités récentes
    function loadRecentActivities() {
        const activities = [
            { type: 'delivery', message: 'Colis livré à Yaoundé' },
            { type: 'mission', message: 'Nouvelle mission acceptée' },
            { type: 'payment', message: 'Paiement reçu pour la mission #1234' },
        ];

        const activitiesContainer = document.getElementById('recentActivities');
        activitiesContainer.innerHTML = '';

        activities.forEach(activity => {
            const li = document.createElement('li');
            li.className = 'flex items-center text-sm';
            const dotColor = activity.type === 'delivery' ? 'bg-green-500' : activity.type === 'mission' ? 'bg-yellow-500' : 'bg-red-500';
            li.innerHTML = `
                <span class="w-4 h-4 rounded-full ${dotColor} mr-2"></span>
                ${activity.message}
            `;
            activitiesContainer.appendChild(li);
        });
    }

    // Fonction pour charger les statistiques de l'utilisateur
    function loadUserStats() {
        document.getElementById('sentPackages').textContent = '15';
        document.getElementById('deliveredPackages').textContent = '12';
        document.getElementById('averageRating').textContent = '4.8';
        document.getElementById('totalEarnings').textContent = '250 FCFA';
    }

    // Initialiser la carte avec la géolocalisation
    if ("geolocation" in navigator) {
        navigator.geolocation.getCurrentPosition(function(position) {
            const latitude  = position.coords.latitude;
            const longitude = position.coords.longitude;
            
            // Initialiser la carte avec la position de l'utilisateur
            initializeMap(longitude, latitude);
        }, function(error) {
            console.error("Erreur de géolocalisation : ", error);
            // En cas d'erreur, utiliser une position par défaut (par exemple, Yaoundé)
            initializeMap(11.5021, 3.8480);
        });
    } else {
        console.log("La géolocalisation n'est pas supportée par ce navigateur.");
        // Si la géolocalisation n'est pas supportée, utiliser une position par défaut
        initializeMap(11.5021, 3.8480);
    }

    // Charger les données au chargement de la page
    document.addEventListener('DOMContentLoaded', () => {
        loadRecentActivities();
        loadUserStats();
    });
</script>

