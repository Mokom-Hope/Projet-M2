    // Capture d'image
    const packageImagePreview = document.getElementById('packageImagePreview');
    const packageImageInput = document.getElementById('packageImage');
    const capturePackageImageButton = document.getElementById('capturePackageImage');

    capturePackageImageButton.addEventListener('click', async () => {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ 
                video: { 
                    facingMode: 'environment' // Utilise la caméra arrière
                }, 
                audio: false 
            });
            
            // Nettoyer le contenu précédent
            packageImagePreview.innerHTML = '';
            
            // Créer et configurer l'élément vidéo
            const video = document.createElement('video');
            video.srcObject = stream;
            video.style.width = '100%';
            video.style.height = '100%';
            video.style.objectFit = 'cover';
            video.play();

            // Ajouter la vidéo au conteneur
            packageImagePreview.appendChild(video);
            
            // Masquer le bouton "Prendre une photo"
            capturePackageImageButton.style.display = 'none';

            // Créer et configurer le bouton de capture
            const captureButton = document.createElement('button');
            captureButton.textContent = 'Capturer';
            captureButton.className = 'absolute bottom-4 left-1/2 transform -translate-x-1/2 px-4 py-2 bg-coligo-blue text-white font-medium rounded-md shadow-sm hover:bg-coligo-orange focus:outline-none focus:ring-2 focus:ring-coligo-blue z-10';
            packageImagePreview.appendChild(captureButton);

            captureButton.addEventListener('click', () => {
                const canvas = document.createElement('canvas');
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);

                canvas.toBlob(blob => {
                    const reader = new FileReader();
                    reader.onloadend = () => {
                        packageImageInput.value = reader.result;
                        
                        // Afficher l'image capturée
                        packageImagePreview.innerHTML = `<img src="${reader.result}" alt="Aperçu de l'image" class="w-full h-full object-cover">`;
                        
                        // Réafficher le bouton "Prendre une photo"
                        capturePackageImageButton.style.display = 'block';
                    };
                    reader.readAsDataURL(blob);
                }, 'image/jpeg');

                // Arrêter la capture vidéo
                stream.getTracks().forEach(track => track.stop());
            });
        } catch (error) {
            console.error('Erreur lors de l\'accès à la caméra :', error);
            alert('Impossible d\'accéder à la caméra. Veuillez vérifier les permissions et réessayer.');
        }
    });

    // Fonction pour convertir une image en base64
    function convertToBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result);
            reader.onerror = error => reject(error);
        });
    }

    // Gestionnaire pour le formulaire d'envoi de colis
    document.getElementById('sendPackageForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Récupération des valeurs
        const formData = new FormData(e.target);
        
        // Ajout de la position actuelle
        const position = userMarker.getLngLat();
        formData.append('latitude', position.lat);
        formData.append('longitude', position.lng);

        // Conversion de l'image en base64
        const imageFile = document.getElementById('packageImage').files[0];
        if (imageFile) {
            formData.append('imgColis', imageFile);
        }
        try {
            // Envoi de la requête
            const response = await fetch('/enregistrerColis', {
                method: 'POST',
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                    'Accept': 'application/json'
                },
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                alert('Colis enregistré avec succès !');
                document.getElementById('sendPackageModal').classList.add('hidden');
                // Recharger les colis à proximité
                loadNearbyPackages(position.lng, position.lat);
            } else {
                alert(result.message || 'Une erreur est survenue lors de l\'enregistrement du colis.');
            }
        } catch (error) {
            console.error('Erreur:', error);
            alert('Une erreur est survenue lors de l\'enregistrement du colis.');
        }
    });
    // ajout de l'enregistrement  //

    
</script>
@endsection